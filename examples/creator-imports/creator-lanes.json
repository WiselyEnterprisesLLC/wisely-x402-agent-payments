{
  "$schema": "../../schemas/creator-lane.schema.json",
  "schema": "wisely.creator-import-lanes.v1",
  "normalizedFields": [
    "title",
    "summary",
    "itemType",
    "tags",
    "entitlement",
    "sourceRef",
    "subscriberInputPrompt",
    "priceUsd",
    "paidActionSlug",
    "approved"
  ],
  "lanes": [
    {
      "id": "markdown_outline",
      "label": "Markdown or pasted outline",
      "status": "live_export_lane",
      "contentType": "markdown",
      "sampleFile": "notion-playbook.md",
      "aliases": ["markdown", "outline", "paste"],
      "acceptedInputs": ["approved Markdown", "course outline", "lesson summaries", "pasted creator-owned text"],
      "whatToTellCreator": "Paste a clean outline, lesson summary, checklist, or framework. Mark anything paid in the title or summary.",
      "doNotCollect": ["platform passwords", "private student/member data", "raw payment details"],
      "defaultEntitlement": "free"
    },
    {
      "id": "video_transcript",
      "label": "Video transcript or lesson video notes",
      "status": "live_export_lane",
      "contentType": "markdown",
      "sampleFile": "video-transcript.md",
      "aliases": ["video", "youtube", "vimeo", "transcript", "lesson-video"],
      "acceptedInputs": ["transcripts", "chapter summaries", "public video links with creator approval", "timestamped notes"],
      "whatToTellCreator": "Export or paste transcripts and timestamped notes. Wisely turns the approved teaching points into searchable lessons and paid actions.",
      "doNotCollect": ["platform logins", "unlicensed videos", "private student clips"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "pdf_text",
      "label": "PDF, workbook, or slide deck text",
      "status": "live_export_lane",
      "contentType": "markdown",
      "sampleFile": "pdf-text.md",
      "aliases": ["pdf", "workbook", "slides", "deck"],
      "acceptedInputs": ["extracted PDF text", "workbook section summaries", "slide notes", "public resource links"],
      "whatToTellCreator": "Paste extracted text or summaries from creator-owned PDFs, worksheets, or slide decks. Keep private student submissions out.",
      "doNotCollect": ["locked course credentials", "private student work", "copyrighted third-party PDFs"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "notion_export",
      "label": "Notion export",
      "status": "live_export_lane",
      "contentType": "markdown",
      "sampleFile": "notion-playbook.md",
      "aliases": ["notion", "notion-md", "notion-export"],
      "acceptedInputs": ["Notion Markdown export", "approved public Notion page text", "creator-owned playbooks"],
      "whatToTellCreator": "Export Notion as Markdown/CSV or paste approved pages. Wisely does not need a Notion token for V0.",
      "doNotCollect": ["Notion API tokens", "workspace admin passwords", "private client pages"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "kajabi_export",
      "label": "Kajabi export",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "kajabi-export.csv",
      "aliases": ["kajabi", "kojabi", "kajabi-csv"],
      "acceptedInputs": ["Kajabi offer/module exports", "lesson summaries", "download/resource inventory", "approved transcript text"],
      "whatToTellCreator": "Export the course/module list or paste the lesson inventory. Wisely maps modules, freebies, and paid actions into the catalog.",
      "doNotCollect": ["Kajabi passwords", "Kajabi admin API keys", "student purchase records"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "teachable_export",
      "label": "Teachable export",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "teachable-export.csv",
      "aliases": ["teachable", "teachable-csv"],
      "acceptedInputs": ["course section export", "lecture summaries", "download/resource inventory"],
      "whatToTellCreator": "Export course sections/lectures or paste a lecture inventory. Wisely turns lectures into agent-readable items.",
      "doNotCollect": ["Teachable passwords", "student rosters", "payment records"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "skool_community",
      "label": "Skool or community classroom export",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "skool-community.csv",
      "aliases": ["skool", "community", "classroom"],
      "acceptedInputs": ["classroom module list", "approved community FAQ", "public classroom links"],
      "whatToTellCreator": "Send an approved classroom/module list and recurring FAQ. Wisely keeps private member data out of the catalog.",
      "doNotCollect": ["member private messages", "Skool passwords", "member emails unless explicitly consented"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "discord_community",
      "label": "Discord or community FAQ export",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "discord-community-faq.csv",
      "aliases": ["discord", "discord-faq", "forum", "community-faq"],
      "acceptedInputs": ["approved FAQ", "public channel exports", "moderator-curated recurring questions"],
      "whatToTellCreator": "Paste or upload a moderator-approved FAQ. Use public/approved summaries, not raw private chats.",
      "doNotCollect": ["Discord bot tokens", "private DMs", "private member data", "server admin credentials"],
      "defaultEntitlement": "free"
    },
    {
      "id": "membership_export",
      "label": "Membership library export",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "membership-export.csv",
      "aliases": ["membership", "circle", "patreon", "members"],
      "acceptedInputs": ["content library inventory", "tier labels", "approved member resources", "public post summaries"],
      "whatToTellCreator": "Export or paste the library map with tier labels. Wisely maps free, subscriber, and paid items without taking platform credentials.",
      "doNotCollect": ["member billing records", "platform passwords", "private DMs"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "teams_training",
      "label": "Teams, cohort, or internal training lane",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "teams-training.csv",
      "aliases": ["teams", "cohort", "training", "company-training"],
      "acceptedInputs": ["training outline", "SOP summaries", "role checklists", "approved internal docs"],
      "whatToTellCreator": "Upload approved training material and role checklists. Paid actions can become roleplay, assessment, or checklist generators.",
      "doNotCollect": ["employee PII", "confidential customer data", "company passwords"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "affiliate_offer",
      "label": "Affiliate or partner offer lane",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "affiliate-offer.csv",
      "aliases": ["affiliate", "partner", "sponsor"],
      "acceptedInputs": ["approved offer descriptions", "affiliate links", "qualification rules", "disclosure text"],
      "whatToTellCreator": "Provide approved affiliate resources and required disclosures. Agents can recommend offers only when they match the subscriber situation.",
      "doNotCollect": ["hidden tracking scripts", "undisclosed paid endorsements", "platform passwords"],
      "defaultEntitlement": "free"
    },
    {
      "id": "revenue_split",
      "label": "Revenue split or co-creator lane",
      "status": "live_export_lane",
      "contentType": "json",
      "sampleFile": "revenue-split.json",
      "aliases": ["revshare", "revenue-share", "split", "co-creator"],
      "acceptedInputs": ["co-creator catalog items", "public split notes", "partner attribution", "payout labels"],
      "whatToTellCreator": "Define which paid actions belong to which partner. This creates catalog metadata and payout labels, not legal advice.",
      "doNotCollect": ["bank credentials", "tax IDs", "private legal agreements"],
      "defaultEntitlement": "paid"
    },
    {
      "id": "token_gated_content",
      "label": "Token-gated content lane",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "token-gated-content.csv",
      "aliases": ["token-gated", "nft", "wallet-gated", "token"],
      "acceptedInputs": ["public token gate rule", "contract or collection reference", "approved unlock description"],
      "whatToTellCreator": "Describe the token/wallet eligibility rule and the approved unlocks. Verification remains a configured entitlement check, not a request for seed phrases.",
      "doNotCollect": ["seed phrases", "private keys", "wallet recovery data"],
      "defaultEntitlement": "subscriber"
    },
    {
      "id": "marketplace_listing",
      "label": "Marketplace search/listing lane",
      "status": "live_export_lane",
      "contentType": "csv",
      "sampleFile": "marketplace-listing.csv",
      "aliases": ["marketplace", "directory", "listing", "search"],
      "acceptedInputs": ["public product listings", "approved service catalog", "pricing table", "public docs links"],
      "whatToTellCreator": "Send public listing rows or a service catalog. Wisely makes the catalog searchable and can attach paid action endpoints.",
      "doNotCollect": ["seller account passwords", "customer order data", "private API keys"],
      "defaultEntitlement": "free"
    }
  ]
}
