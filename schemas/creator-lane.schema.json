{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wiselyenterprisesllc.com/schemas/creator-lane.schema.json",
  "title": "Wisely Creator Import Lanes",
  "type": "object",
  "required": ["schema", "normalizedFields", "lanes"],
  "properties": {
    "schema": { "const": "wisely.creator-import-lanes.v1" },
    "normalizedFields": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "status", "contentType", "sampleFile", "acceptedInputs", "whatToTellCreator", "doNotCollect", "defaultEntitlement"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "label": { "type": "string" },
          "status": { "enum": ["live_export_lane", "planned_direct_connector", "disabled"] },
          "contentType": { "enum": ["markdown", "csv", "json"] },
          "sampleFile": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "acceptedInputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "whatToTellCreator": { "type": "string" },
          "doNotCollect": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "defaultEntitlement": { "enum": ["free", "subscriber", "paid"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
